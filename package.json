{
  "name": "xrift-studio",
  "private": true,
  "version": "0.5.10",
  "description": "Community-built desktop app for creating XRift worlds and items",
  "type": "module",
  "license": "MIT",
  "author": "xrift-studio contributors",
  "bin": {
    "xrift-studio": "./dist/cli/xrift-studio.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:preview": "vite build --config vite.preview.config.ts",
    "starter:sync:xrift-official": "node scripts/sync-xrift-official-starter-assets.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "mcp:sidecar:prepare": "node scripts/prepare-mcp-sidecar.mjs",
    "mcp:sidecar:prepare:release": "node scripts/prepare-mcp-sidecar.mjs --release",
    "mcp:server": "pnpm dlx @hypothesi/tauri-mcp-server",
    "mcp:cli": "pnpm --package=@hypothesi/tauri-mcp-cli dlx tauri-mcp",
    "e2e:typecheck": "tsc --noEmit -p tsconfig.e2e.json",
    "e2e:release": "pnpm typecheck && pnpm e2e:typecheck && playwright test --config playwright.config.ts",
    "cli:build": "vite build --config vite.cli.config.mjs",
    "cli:test": "pnpm cli:build && node dist/cli/fixture.mjs",
    "runtime:build": "pnpm --filter xrift-studio-runtime build",
    "runtime:typecheck": "pnpm --filter xrift-studio-runtime typecheck"
  },
  "overrides": {
    "dompurify": "3.4.12"
  },
  "dependencies": {
    "@gltf-transform/core": "4.4.1",
    "@gltf-transform/extensions": "4.4.1",
    "@gltf-transform/functions": "4.4.1",
    "@monaco-editor/react": "4.7.0",
    "@pixiv/three-vrm": "3.5.5",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/rapier": "2.2.0",
    "@react-three/uikit": "1.0.62",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xrift/world-components": "0.43.0",
    "@xyflow/react": "12.11.2",
    "draco3dgltf": "1.5.7",
    "hls.js": "1.6.13",
    "ktx2-encoder": "0.6.0",
    "lucide-react": "1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rhino3dm": "8.17.0",
    "three": "0.185.1",
    "three-icosa": "0.4.2-alpha.18",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "draco3d": "1.5.7",
    "tailwindcss": "4.3.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.5"
  }
}
