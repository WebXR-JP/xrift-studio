{
  "name": "xrift-studio",
  "private": true,
  "version": "0.4.0",
  "description": "Community-built desktop app for creating XRift worlds and items",
  "type": "module",
  "license": "MIT",
  "author": "xrift-studio contributors",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:preview": "vite build --config vite.preview.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "mcp:server": "pnpm dlx @hypothesi/tauri-mcp-server",
    "mcp:cli": "pnpm dlx @hypothesi/tauri-mcp-cli"
  },
  "overrides": {
    "dompurify": "3.4.12"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@pixiv/three-vrm": "3.5.5",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-shell": "2.3.5",
    "lucide-react": "1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "0.185.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "4.3.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.5"
  }
