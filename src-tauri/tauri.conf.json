{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XRift Studio",
  "version": "0.4.0",
  "identifier": "net.xrift.studio",
  "build": {
    "beforeDevCommand": "pnpm mcp:sidecar:prepare && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm mcp:sidecar:prepare:release && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "XRift Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/xrift-studio-mcp-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3NDgyREJDM0U1NTVCQgpSV1M3VmVYRDI0SjBEK1dIb3VMdllzNW8rZ2JQUE1UUVpieDRNSEpkeVovN205SUU4eUFlbjJQUwo=",
      "endpoints": [
        "https://github.com/WebXR-JP/xrift-studio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
